{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "finalnexhr-api"
      }
    }
  ],
  "services": {
    "finalnexhr-api": {
      "root": ".",
      "framework": "express",
      "entrypoint": "api/index.ts",
      "buildCommand": "npm install && npm run build"
    }
  }
}
